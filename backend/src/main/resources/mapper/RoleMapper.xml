<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hjc.kgms.mapper.RoleMapper">

    <select id="selectAll" resultType="com.hjc.kgms.model.entity.SysRole">
        SELECT id, role_code, role_name
        FROM sys_role
        ORDER BY id
